# Required Environment Variables
NODE_ENV=development

# Database (required)
MONGODB_URI=mongodb://localhost:27017/veritas

# API Configuration
PORT=3000
HOST=localhost

# CORS — comma-separated list of allowed origins.
# REQUIRED in production (startup fails on wildcard/unset).
# Dev default when unset: http://localhost:4200,http://localhost:3000
# CORS_ORIGIN=https://app.example.com

# Authentication
# API key required on every request via `x-api-key` header when set.
# REQUIRED in production (startup fails without it). Unset = open dev mode.
# VERITAS_API_KEY=generate-a-long-random-string
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# === Source politeness / caching ===
# Per-platform rate limit overrides, JSON. Defaults are conservative.
# SOURCE_RATE_LIMITS='{"reddit":{"minIntervalMs":3000,"maxConcurrent":1}}'
# Cross-scan fetch cache TTL in minutes (0 disables). Default: 30.
# CONNECTOR_CACHE_TTL_MINUTES=30
# Opt-in: let the LLM hypothesize synthetic signals in downstream-effects.
# ENABLE_LLM_HYPOTHESIS_SIGNALS=false

# === Data Connectors (all API-free by default) ===

# Twitter/X - requires a free Twitter account
# Option 1: Session cookies from browser DevTools
# TWITTER_COOKIES='["auth_token=YOUR_TOKEN; Domain=.x.com", "ct0=YOUR_CT0; Domain=.x.com"]'
# Option 2: Username/password login
# TWITTER_USERNAME=
# TWITTER_PASSWORD=
# TWITTER_EMAIL=
# TWITTER_2FA_SECRET=

# Facebook - monitors public pages via Jina Reader
# FACEBOOK_PAGE_URLS='["https://www.facebook.com/somepage"]'

# Reddit - uses public JSON API, no auth needed
# REDDIT_USER_AGENT=Veritas/1.0.0

# YouTube - uses yt-dlp, no auth needed
# YT_DLP_PATH=yt-dlp

# Jina Reader - free tier, optional API key for higher limits
# JINA_API_KEY=

# === Optional: Legacy API-key connectors ===
# Set connector mode to 'api' in IngestionModule.forRoot() to use these
# TWITTER_BEARER_TOKEN=
# FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_PAGE_ID=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# === Optional Infrastructure ===

# Memgraph (graph database)
# MEMGRAPH_URI=bolt://localhost:7687
# MEMGRAPH_USERNAME=
# MEMGRAPH_PASSWORD=

# Redis (caching)
# REDIS_URI=redis://localhost:6379

# Kafka (event streaming)
# KAFKA_BROKERS=localhost:9092

# Embeddings
# OPENAI_API_KEY=

# Logging
LOG_LEVEL=debug

# Monitoring
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
