# Required Environment Variables
NODE_ENV=development

# Database (required)
MONGODB_URI=mongodb://localhost:27017/veritas

# API Configuration
PORT=3000
HOST=localhost

# CORS — comma-separated list of allowed origins.
# REQUIRED in production (startup fails on wildcard/unset).
# Dev default when unset: http://localhost:4200,http://localhost:3000
# CORS_ORIGIN=https://app.example.com

# Authentication
# API key required on every request via `x-api-key` header when set.
# REQUIRED in production (startup fails without it). Unset = open dev mode.
# VERITAS_API_KEY=generate-a-long-random-string
# NOTE: API auth is via VERITAS_API_KEY only. There is no JWT/user auth yet —
# JWT-based user accounts are future work.

# === Source politeness / caching ===
# Per-platform rate limit overrides, JSON. Defaults are conservative.
# SOURCE_RATE_LIMITS='{"reddit":{"minIntervalMs":3000,"maxConcurrent":1}}'
# Cross-scan fetch cache TTL in minutes (0 disables). Default: 30.
# CONNECTOR_CACHE_TTL_MINUTES=30
# Opt-in: let the LLM hypothesize synthetic signals in downstream-effects.
# ENABLE_LLM_HYPOTHESIS_SIGNALS=false

# === LLM (analysis) ===
# Required for LLM features (propaganda analysis, claim verification,
# embeddings-based clustering). Unset = heuristic/degraded mode.
GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_REASONING_MODEL=gemini-3.1-pro-preview
# LLM cost controls (LlmGateway): concurrency cap, response-cache TTL (0=off),
# and per-investigation token budget beyond which calls degrade to heuristics.
# LLM_MAX_CONCURRENCY=4
# LLM_CACHE_TTL_MINUTES=60
# LLM_MAX_TOKENS_PER_CONTEXT=2000000
# Embedding tunables (defaults are sensible)
# GEMINI_EMBEDDING_MODEL=
# GEMINI_EMBED_BATCH_SIZE=
# GEMINI_EMBED_CHAR_LIMIT=
# GEMINI_EMBED_MAX_RETRIES=
# GEMINI_EMBED_RETRY_BASE_MS=

# === Signal / evidence adapters (all optional) ===
# FRED_API_KEY=            # US economic data (FRED)
# ETHERSCAN_API_KEY=       # On-chain evidence
# GITHUB_TOKEN=            # GitHub evidence (higher rate limits)
# ACLED_ENABLED=false      # Conflict data (requires registration)
# ACLED_API_KEY=
# ACLED_EMAIL=

# === Data Connectors (all API-free by default) ===

# Twitter/X - requires a free Twitter account
# Option 1: Session cookies from browser DevTools
# TWITTER_COOKIES='["auth_token=YOUR_TOKEN; Domain=.x.com", "ct0=YOUR_CT0; Domain=.x.com"]'
# Option 2: Username/password login
# TWITTER_USERNAME=
# TWITTER_PASSWORD=
# TWITTER_EMAIL=
# TWITTER_2FA_SECRET=

# Facebook - monitors public pages via Jina Reader
# FACEBOOK_PAGE_URLS='["https://www.facebook.com/somepage"]'

# Reddit - uses public JSON API, no auth needed
# REDDIT_USER_AGENT=Veritas/1.0.0

# YouTube - uses yt-dlp, no auth needed
# YT_DLP_PATH=yt-dlp

# Jina Reader - free tier, optional API key for higher limits
# JINA_API_KEY=

# Farcaster - Neynar API v2 (free tier key)
# NEYNAR_API_KEY=

# === Optional: Legacy API-key connectors ===
# Set connector mode to 'api' in IngestionModule.forRoot() to use these
# TWITTER_BEARER_TOKEN=
# FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_PAGE_ID=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# === Optional Infrastructure ===

# Memgraph (graph database)
# MEMGRAPH_URI=bolt://localhost:7687
# MEMGRAPH_HOST=localhost
# MEMGRAPH_PORT=7687
# MEMGRAPH_USERNAME=
# MEMGRAPH_PASSWORD=

# Redis — BullMQ job queues (scan/analysis workers). Defaults to localhost.
# REDIS_HOST=localhost
# REDIS_PORT=6379
