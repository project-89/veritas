{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "preserveSymlinks": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "paths": {
      "@/*": ["apps/api/src/*"],
      "@/app.module": ["apps/api/src/app/app.module.ts"],
      "@/modules/*": ["apps/api/src/app/modules/*"],
      "@/services/*": ["apps/api/src/app/services/*"],
      "@veritas-nx/visualization": ["libs/visualization/src/index.ts"],
      "@veritas/analysis": ["libs/analysis/src/index.ts"],
      "@veritas/client/api": ["apps/veritas-client/lib/api.ts"],
      "@veritas/client/nerv/*": ["apps/veritas-client/components/nerv/*"],
      "@veritas/content-classification": ["libs/content-classification/src/index.ts"],
      "@veritas/database": ["libs/database/src/index.ts"],
      "@veritas/ingestion": ["libs/ingestion/src/index.ts"],
      "@veritas/ingestion/internal/queue/*": ["libs/ingestion/src/lib/queue/*"],
      "@veritas/ingestion/internal/repositories/*": ["libs/ingestion/src/lib/repositories/*"],
      "@veritas/ingestion/internal/schemas/*": ["libs/ingestion/src/lib/schemas/*"],
      "@veritas/plugin-atlas": ["packages/atlas-plugin/src/index.ts"],
      "@veritas/plugin-magi": ["private-plugins/packages/magi-plugin/src/index.ts"],
      "@veritas/plugin-magi/backend": ["private-plugins/packages/magi-plugin/src/backend/index.ts"],
      "@veritas/shared": ["libs/shared/types/src/index.ts"],
      "@veritas/shared/plugins": ["libs/shared/src/lib/plugins/plugin-registry.ts"],
      "@veritas/shared/types": ["libs/shared/types/src/index.ts"],
      "@veritas/shared/utils": ["libs/shared/utils/src/index.ts"],
      "@veritas/sources": ["libs/sources/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
