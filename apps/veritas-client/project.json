{
  "name": "veritas-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/veritas-client",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/veritas-client"
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "veritas-client:build",
        "dev": true,
        "port": 4200
      },
      "configurations": {
        "development": { "buildTarget": "veritas-client:build:development", "dev": true },
        "production": { "buildTarget": "veritas-client:build:production", "dev": false }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": { "passWithNoTests": true }
    }
  }
}
