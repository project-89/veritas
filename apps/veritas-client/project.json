{
  "name": "veritas-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/veritas-client/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project veritas-client --web",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "echo 'Skipping build for veritas-client application'"
        ]
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "veritas-client:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "veritas-client:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "veritas-client:build:production",
          "hmr": false
        }
      }
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "veritas-client:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "veritas-client:build:development"
        },
        "production": {
          "buildTarget": "veritas-client:build:production"
        }
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "passWithNoTests": true,
        "reportsDirectory": "../../coverage/apps/veritas-client"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/veritas-client/**/*.{ts,tsx,js,jsx}"]
      }
    }
  }
}
