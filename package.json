{
  "name": "@veritas-nx/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "test": "nx run-many --target=test --all",
    "test:visualization": "nx test visualization",
    "test:api": "nx test api",
    "test:analysis": "nx test analysis",
    "test:types": "nx test types",
    "test:utils": "nx test utils",
    "test:data-access": "nx test data-access",
    "test:watch": "nx run-many --target=test --all --watch",
    "test:coverage": "nx run-many --target=test --all --coverage",
    "test:affected": "nx affected --target=test",
    "build": "nx run-many --target=build --all",
    "build:visualization": "nx build visualization",
    "build:api": "nx build api",
    "build:veritas-client": "nx build veritas-client",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "biome:check": "biome check --write .",
    "biome:lint": "biome check .",
    "serve:api": "nx serve api",
    "serve:visualization": "nx serve visualization",
    "serve:veritas-client": "nx serve veritas-client",
    "dev": "nx run-many --target=serve --projects=api,veritas-client --parallel=2",
    "clean:build": "find . -type f -name \"*.js\" -not -path \"*/node_modules/*\" -not -path \"*/dist/*\" -not -path \"*/scripts/*\" -not -name \"jest.config.js\" -not -name \"jest.preset.js\" -not -name \"*.config.js\" -delete && find . -type f -name \"*.d.ts\" -not -path \"*/node_modules/*\" -not -path \"*/dist/*\" -not -path \"*/types/*\" -delete && find . -type f -name \"*.js.map\" -not -path \"*/node_modules/*\" -not -path \"*/dist/*\" -delete && find . -type f -name \"*.tsbuildinfo\" -not -path \"*/node_modules/*\" -not -path \"*/dist/*\" -delete",
    "mongodb:up": "docker-compose -f docker-compose.mongodb.yml up -d",
    "mongodb:down": "docker-compose -f docker-compose.mongodb.yml down",
    "mongodb:reset": "docker-compose -f docker-compose.mongodb.yml down && rm -rf ./mongodb_data && docker-compose -f docker-compose.mongodb.yml up -d"
  },
  "private": true,
