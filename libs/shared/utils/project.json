{
  "name": "utils",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/utils/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/utils",
        "main": "libs/shared/utils/src/index.ts",
        "tsConfig": "libs/shared/utils/tsconfig.lib.json",
        "assets": ["libs/shared/utils/*.md"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "env -u NO_COLOR pnpm exec jest --config libs/shared/utils/jest.config.ts --passWithNoTests --watchman=false",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
