{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "types": ["jest", "node"],
    "declaration": true,
    "esModuleInterop": true,
    "allowJs": true,
    "baseUrl": "../..",
    "paths": {
      "@veritas/shared/types": ["libs/shared/types/src/index.ts"],
      "@veritas/shared": ["libs/shared/types/src/index.ts"],
      "@veritas/database": ["libs/database/src/index.ts"]
    }
  },
  "include": [
    "jest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
} 