{
  "name": "analysis",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/analysis/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/analysis",
        "main": "libs/analysis/src/index.ts",
        "tsConfig": "libs/analysis/tsconfig.lib.json",
        "assets": ["libs/analysis/*.md"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "env -u NO_COLOR pnpm exec jest --config libs/analysis/jest.config.ts --passWithNoTests --watchman=false",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
