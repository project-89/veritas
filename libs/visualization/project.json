{
  "name": "visualization",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/visualization/src",
  "projectType": "library",
  "tags": [],
  "// targets": "to see all targets run: nx show project visualization --web",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "options": {
        "skipLibCheck": true,
        "skipTypeCheck": true,
        "outputPath": "dist/libs/visualization",
        "main": "libs/visualization/src/index.ts",
        "tsConfig": "libs/visualization/tsconfig.lib.json",
        "assets": ["libs/visualization/*.md"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "env -u NO_COLOR pnpm exec jest --config libs/visualization/jest.config.ts --passWithNoTests --watchman=false",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
