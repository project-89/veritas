{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["libs/*"],
      "@veritas/ingestion": ["libs/ingestion/src/index.ts"],
      "@veritas/ingestion/*": ["libs/ingestion/src/*"],
      "@veritas/analysis": ["libs/analysis/src/index.ts"],
      "@veritas/analysis/*": ["libs/analysis/src/*"],
      "@veritas/database": ["libs/database/src/index.ts"],
      "@veritas/database/*": ["libs/database/src/*"],
      "@veritas/content-classification": ["libs/content-classification/src/index.ts"],
      "@veritas/content-classification/*": ["libs/content-classification/src/*"],
      "@veritas/shared": ["libs/shared/src/index.ts"],
      "@veritas/shared/*": ["libs/shared/src/*"],
      "@veritas/shared/types": ["libs/shared/types/src/index.ts"],
      "@veritas/visualization": ["libs/visualization/src/index.ts"],
      "@veritas/visualization/*": ["libs/visualization/src/*"],
      "@veritas/sources": ["libs/sources/src/index.ts"],
      "@veritas/sources/*": ["libs/sources/src/*"]
    },
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "include": [
    "libs/**/*",
    "apps/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.d.ts",
    "**/*.js"
  ]
} 